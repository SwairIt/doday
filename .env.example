# Copy this file to .env and fill in real values. .env is gitignored.

# === GitHub PAT for pushing to origin master (used by collaborator scripts) ===
TOKEN=ghp_replace_me_with_real_token

# === App ===
APP_ENV=dev
# Random ≥32 chars for session signing.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=replace-with-32-or-more-random-bytes-please
APP_BASE_URL=http://localhost:9000
LOG_LEVEL=INFO

# === Postgres — main DB used by the app and by Alembic migrations ===
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# For this dev box: localhost:5433 (SSH tunnel to remote Postgres)
DATABASE_URL=postgresql+asyncpg://schooltodo:replace_me@localhost:5433/schooltodo

# === Postgres — separate test DB. conftest TRUNCATEs all tables between tests. ===
TEST_DATABASE_URL=postgresql+asyncpg://schooltodo:replace_me@localhost:5433/schooltodo_test

# === SMTP — used by app/auth/email.py to send verification emails ===
# Defaults below assume a local debug SMTP (e.g. aiosmtpd). Switch to a real
# provider before public launch.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@schooltodo.local
# Set to true for providers like Resend/Brevo on port 587 (STARTTLS).
SMTP_START_TLS=false
