# Copy this file to .env and fill in real values. .env is gitignored.
#
# In production, fill the same keys but with prod values:
#   APP_ENV=prod, APP_BASE_URL=https://your-domain, strong APP_SECRET_KEY,
#   real SMTP credentials, Postgres password used by both `db` and `web`
#   compose services. See DEPLOY.md for the walkthrough.

# === GitHub PAT for pushing to origin master (collaborator scripts only) ===
TOKEN=ghp_replace_me_with_real_token

# === App ===
# `dev` is permissive (HTTP cookies, dev-mode SMTP fallback).
# `prod` enables https_only on session cookies — required for HTTPS deployments.
APP_ENV=dev
# Random ≥32 chars for session signing. Rotate this and every session is invalidated.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=replace-with-32-or-more-random-bytes-please
# Used in verification emails and absolute redirects. In prod = https://your-domain
APP_BASE_URL=http://localhost:9000
LOG_LEVEL=INFO

# === Postgres — main DB used by the app and by Alembic migrations ===
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Local dev: localhost:5432.
# Docker compose: HOST=db (service name), PORT=5432.
DATABASE_URL=postgresql+asyncpg://schooltodo:replace_me@localhost:5432/schooltodo

# === Postgres — separate test DB. conftest TRUNCATEs all tables between tests. ===
# Leave empty in prod (tests don't run there).
TEST_DATABASE_URL=postgresql+asyncpg://schooltodo:replace_me@localhost:5432/schooltodo_test

# === Postgres credentials used by docker-compose.yml to bootstrap the `db` service ===
# Required only when running via `docker compose up`. Pick a long random password.
POSTGRES_USER=doday
POSTGRES_PASSWORD=replace_me_with_a_long_random_password
POSTGRES_DB=doday

# === SMTP — used by app/auth/email.py to send verification emails ===
# Defaults below assume a local debug SMTP (e.g. aiosmtpd on :1025).
# In prod, use Gmail (app password, not main password) or a transactional
# provider like Resend, Brevo, Mailgun.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@schooltodo.local
# Set to true for providers like Gmail/Resend/Brevo on port 587 (STARTTLS).
SMTP_START_TLS=false

# === uvicorn (Docker / systemd) ===
# Workers = (2 × CPU) + 1 is the classic rule. On a 1-core VPS, leave at 2.
UVICORN_WORKERS=2

# === Yandex.Metrika ===
# Counter ID (число типа 12345678). Получить: metrika.yandex.ru → новый счётчик.
# Если пусто — скрипт Метрики не подключается. Безопасно для dev.
YA_METRIKA_ID=

# === Утренний email-дайджест ===
# Secret token для системного cron'а на проде. Демон cron шлёт ежедневный
# `POST /api/digest/cron-trigger` с заголовком `X-Cron-Token: <token>` —
# совпадение проверяется в endpoint'е, неверный → 403, пустой в env → 503.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Если пусто — endpoint отключён (для dev безопасно).
CRON_TOKEN=
