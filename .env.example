# Copy this file to .env and fill in real values. .env is gitignored.
#
# In production, fill the same keys but with prod values:
#   APP_ENV=prod, APP_BASE_URL=https://your-domain, strong APP_SECRET_KEY,
#   real SMTP credentials, Postgres password used by both `db` and `web`
#   compose services. See DEPLOY.md for the walkthrough.

# === GitHub PAT for pushing to origin master (collaborator scripts only) ===
TOKEN=ghp_replace_me_with_real_token

# === App ===
# `dev` is permissive (HTTP cookies, dev-mode SMTP fallback).
# `prod` enables https_only on session cookies — required for HTTPS deployments.
APP_ENV=dev
# Random ≥32 chars for session signing. Rotate this and every session is invalidated.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=replace-with-32-or-more-random-bytes-please
# Used in verification emails and absolute redirects. In prod = https://your-domain
APP_BASE_URL=http://localhost:9000
LOG_LEVEL=INFO

# === Postgres — main DB used by the app and by Alembic migrations ===
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Local dev: localhost:5432.
# Docker compose: HOST=db (service name), PORT=5432.
DATABASE_URL=postgresql+asyncpg://schooltodo:replace_me@localhost:5432/schooltodo

# === Postgres — separate test DB. conftest TRUNCATEs all tables between tests. ===
# Leave empty in prod (tests don't run there).
TEST_DATABASE_URL=postgresql+asyncpg://schooltodo:replace_me@localhost:5432/schooltodo_test

# === Postgres credentials used by docker-compose.yml to bootstrap the `db` service ===
# Required only when running via `docker compose up`. Pick a long random password.
POSTGRES_USER=doday
POSTGRES_PASSWORD=replace_me_with_a_long_random_password
POSTGRES_DB=doday

# === SMTP — used by app/auth/email.py to send verification emails ===
# Defaults below assume a local debug SMTP (e.g. aiosmtpd on :1025).
# In prod, use Gmail (app password, not main password) or a transactional
# provider like Resend, Brevo, Mailgun.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@schooltodo.local
# Set to true for providers like Gmail/Resend/Brevo on port 587 (STARTTLS).
SMTP_START_TLS=false

# === uvicorn (Docker / systemd) ===
# Workers = (2 × CPU) + 1 is the classic rule. On a 1-core VPS, leave at 2.
UVICORN_WORKERS=2

# === Yandex.Metrika ===
# Counter ID (число типа 12345678). Получить: metrika.yandex.ru → новый счётчик.
# Если пусто — скрипт Метрики не подключается. Безопасно для dev.
YA_METRIKA_ID=

# === Утренний email-дайджест ===
# Secret token для системного cron'а на проде. Демон cron шлёт ежедневный
# `POST /api/digest/cron-trigger` с заголовком `X-Cron-Token: <token>` —
# совпадение проверяется в endpoint'е, неверный → 403, пустой в env → 503.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Если пусто — endpoint отключён (для dev безопасно).
CRON_TOKEN=

# === IndexNow key (Lessio SEO) ===
# Ключ для протокола IndexNow (Яндекс + Bing). Должен быть размещён по адресу
# https://<host>/<key>.txt — endpoint app/main.py отдаёт его автоматически когда
# ключ задан здесь. Сгенерировать: python -c "import secrets; print(secrets.token_hex(16))"
# Используется в app/lessio/web_router.py (setup-profile) и cabinet_router.py
# (settings slug-change) — пингует Яндекс при появлении новой /u/<slug>.
INDEXNOW_KEY=

# === Google OAuth for Lessio Calendar busy-times sync ===
# https://console.cloud.google.com/apis/credentials → Create OAuth 2.0 Client ID
# Application type: Web application
# Authorized redirect URIs: https://getdoday.ru/lessio/oauth/google/callback
# Scopes (configured в OAuth consent screen): .../auth/calendar.readonly
# Если пусто — в Settings скрыта кнопка «Подключить Google Calendar» (опц. фича).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# === Admin API token ===
# Secret token для GET /api/admin/complaints.json — позволяет оператору
# (или Claude через bash) curl'ить жалобы юзеров без cookie-сессии.
# Header `X-Admin-Token: <token>` обязателен. Пустой в dev → 503.
# Не путать с CRON_TOKEN — это разные секреты.
ADMIN_TOKEN=

# === Telegram bots ===
# @DodayTaskBot — основной бот Doday Tasks. Без токена bot worker не стартует.
# Получить: @BotFather → /newbot → токен → handle (без @) → /setname /setdescription.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=DodayTaskBot

# @LessioBot — отдельный бот Lessio для brand-separation от Doday Tasks.
# Один worker процесс крутит оба бота через два Application в одном asyncio loop
# (см. app/telegram/bot.py main()). Пустой LESSIO_BOT_TOKEN → Lessio bot disabled,
# Doday работает как раньше (graceful degradation).
# Stars-invoice для tutor_pro_* продуктов выписываются на @LessioBot (см.
# app/billing/stars.py _bot_token_for_product), доход идёт на этот бот в Telegram.
LESSIO_BOT_TOKEN=
LESSIO_BOT_USERNAME=LessioBot

# === Telegram API proxy (только для прода если RKN/провайдер блокирует) ===
# Если api.telegram.org недостижим напрямую с прод-сервера (TimedOut на TLS-handshake),
# поставь HTTP/SOCKS5-прокси:
#   http://USER:PASS@HOST:PORT
#   socks5://USER:PASS@HOST:PORT  (нужен `uv add 'httpx[socks]'`)
# Пусто = bot ходит напрямую. На dev обычно работает без прокси.
TELEGRAM_PROXY_URL=

# === Bot worker flags ===
# DISABLE_DODAY_BOT=1 — для local-dev: запустить только Lessio bot (Doday Application
# пропустить чтобы не конкурировать за getUpdates на @DodayTaskBot). Дефолт пусто.
DISABLE_DODAY_BOT=
# DISABLE_TELEGRAM_IPV4_PATCH=1 — отключить hardcoded-IPv4-resolver. Нужно когда
# hardcoded список устарел; в combo с TELEGRAM_PROXY_URL обычно не нужен (прокси сам резолвит).
DISABLE_TELEGRAM_IPV4_PATCH=
