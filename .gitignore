package-lock.json

# ── Dev / debug screenshots ───────────────────────────────────────────────
# Root-level images — historically these were design-audit screenshots,
# competitor landings, dev-iteration snapshots. None of them belong in the
# repo. If you need a screenshot for README/docs, put it in docs/screenshots/
# with a meaningful name (e.g. landing-hero.png, miniapp-today.png).
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.bmp

# Debug screenshots from automated UI checks — they get regenerated every
# session and have zero value for repo visitors. If you need a screenshot in
# README/docs, force-add it: `git add -f docs/screenshots/landing-hero.png`.
docs/screenshots/*.png
docs/screenshots/*.jpg
docs/screenshots/*.gif
docs/screenshots/*.webp
docs/screenshots/_debug/
docs/screenshots/audit-*

# ── Sentry / metrics ──────────────────────────────────────────────────────
.sentryclirc

# ── Local override files / ad-hoc scripts ─────────────────────────────────
local.py
override.py
scratch/
playground/

# ── macOS / Windows artifacts ─────────────────────────────────────────────
*.icloud
$RECYCLE.BIN/
System Volume Information/

# Local bot worker runtime artifacts — never tracked.
.bot.local.*
